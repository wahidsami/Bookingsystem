# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=rifah_shared
DB_HOST=localhost
DB_PORT=5434

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your-super-secure-jwt-secret-key-at-least-32-characters-long
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-key-at-least-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration - Resend (used for tenant approval, welcome, rejection emails)
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=Rifah Platform <onboarding@yourdomain.com>
# Optional: tenant dashboard URL (in approval email). If unset, falls back to http://localhost:3003/ar/login
# TENANT_DASHBOARD_URL=https://tenant.yourdomain.com/ar/login
# Optional: separate payment/subscription link in approval email. If unset, same as TENANT_DASHBOARD_URL
# TENANT_PAYMENT_LINK_URL=https://pay.yourdomain.com/...

# API Keys (optional)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

# Logging
LOG_LEVEL=info
